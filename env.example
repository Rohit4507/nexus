# NEXUS Environment Configuration
ENV=development
LOG_LEVEL=INFO

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus
DB_USER=nexus
DB_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6379

# LLM (Ollama)
OLLAMA_URL=http://localhost:11434

# Meeting Recording Storage
MEETING_RECORDING_STORAGE=local
MEETING_RECORDING_LOCAL_DIR=data/meetings
MEETING_AUTO_TRIGGER_THRESHOLD=0.8

# AWS S3 (Optional - for production)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# MEETING_RECORDING_S3_BUCKET=company-meetings
# MEETING_RECORDING_S3_PREFIX=recordings
